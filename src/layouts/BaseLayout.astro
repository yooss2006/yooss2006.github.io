---
import { ClientRouter } from "astro:transitions";
import RainSoundToggle from "@/components/RainSoundToggle.astro";
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  currentPath?: "/" | "/posts/" | "/about/";
}

const { title, description, currentPath } = Astro.props;

const navItems = [
  { href: "/posts/", label: "Posts" },
  { href: "/about/", label: "About" },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#content">본문으로 이동</a>

    <div class="site-shell">
      <header class="site-header">
        <a class="site-title" href="/" aria-label="비가 내리네요. 홈">
          비가 내리네요.
        </a>

        <nav class="site-nav" aria-label="주요 메뉴">
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
          <RainSoundToggle />
        </nav>
      </header>

      <main id="content" class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <p>개발과 일상을 오래 남기는 개인 기록장</p>
      </footer>
    </div>
  </body>
</html>
