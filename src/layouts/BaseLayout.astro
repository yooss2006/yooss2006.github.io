---
import { ClientRouter } from "astro:transitions";
import RainOverlay from "@/components/RainOverlay.astro";
import RainSoundToggle from "@/components/RainSoundToggle.astro";
import { siteConfig } from "@/config/site";
import "@/styles/global.css";
import styles from "./BaseLayout.module.css";

interface Props {
  readonly title: string;
  readonly description: string;
  readonly currentPath?: "/" | "/posts/" | "/about/";
  readonly ogType?: "website" | "article";
  readonly ogImage?: string;
  readonly ogImageAlt?: string;
  readonly robots?: "noindex";
  readonly article?: {
    readonly publishedTime: string;
    readonly modifiedTime?: string;
    readonly author: string;
    readonly section: string;
    readonly tags: readonly string[];
  };
}

const {
  title,
  description,
  currentPath,
  ogType = "website",
  ogImage = siteConfig.ogImage,
  ogImageAlt = `${siteConfig.name} 공유 이미지`,
  robots,
  article,
} = Astro.props;
const isHome = currentPath === "/";
const siteUrl = Astro.site ?? new URL(siteConfig.url);
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).toString();
const ogImageUrl = new URL(ogImage, siteUrl).toString();
const rssUrl = new URL(siteConfig.links.rss, siteUrl).toString();
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <meta name="author" content={siteConfig.author} />
    <meta name="application-name" content={siteConfig.name} />
    <meta name="theme-color" content="#121315" />
    {robots && <meta name="robots" content={robots} />}
    <link rel="icon" href="/icons/site/favicon.ico" sizes="any" />
    <link rel="manifest" href="/manifest.webmanifest" />
    <link rel="preload" href="/images/site-logo.png" as="image" fetchpriority="high" />
    <link rel="preload" href="/fonts/Pretendard-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Paperlogy-9Black.ttf" as="font" type="font/ttf" crossorigin />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" type="application/rss+xml" title={`${siteConfig.name} RSS`} href={rssUrl} />
    <meta property="og:site_name" content={siteConfig.name} />
    <meta property="og:locale" content="ko_KR" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:alt" content={ogImageAlt} />
    {
      article && (
        <>
          <meta property="article:published_time" content={article.publishedTime} />
          {article.modifiedTime && <meta property="article:modified_time" content={article.modifiedTime} />}
          <meta property="article:author" content={article.author} />
          <meta property="article:section" content={article.section} />
          {article.tags.map((tag) => (
            <meta property="article:tag" content={tag} />
          ))}
        </>
      )
    }
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />
    <title>{title}</title>
    <script is:inline>
      (() => {
        const key = `rainy-notes:scroll:${location.pathname}${location.search}`;
        const storage = (() => {
          try {
            return sessionStorage;
          } catch {
            return null;
          }
        })();
        const storedY = Number(storage?.getItem(key) || 0);
        const navigationType = performance.getEntriesByType("navigation")[0]?.type;
        const shouldRestore = storedY > 0 && (!navigationType || navigationType === "reload" || navigationType === "back_forward");

        if (shouldRestore) {
          document.documentElement.dataset.scrollRestoring = "true";
        }

        const saveScroll = () => {
          storage?.setItem(key, String(Math.round(scrollY)));
        };

        addEventListener("pagehide", saveScroll);
        addEventListener("beforeunload", saveScroll);

        if (!shouldRestore) {
          return;
        }

        const reveal = () => {
          delete document.documentElement.dataset.scrollRestoring;
        };

        const restore = (attempt = 0) => {
          scrollTo(0, storedY);

          if (Math.abs(scrollY - storedY) <= 2 || attempt >= 20) {
            requestAnimationFrame(reveal);
            return;
          }

          requestAnimationFrame(() => restore(attempt + 1));
        };

        if (document.readyState === "loading") {
          addEventListener("DOMContentLoaded", () => restore(), { once: true });
        } else {
          restore();
        }
      })();
    </script>
    <ClientRouter />
  </head>
  <body>
    <a class={styles.skipLink} href="#content">본문으로 이동</a>
    <RainOverlay enabled={true} intensity="drizzle" />

    <div class={styles.siteShell} data-site-shell>
      <header class={styles.siteHeader}>
        <a class={styles.siteTitle} href={isHome ? undefined : "/"} aria-current={isHome ? "page" : undefined} aria-label={`${siteConfig.name} 홈`}>
          <img
            class={styles.siteTitleLogo}
            src={siteConfig.logo}
            alt={siteConfig.name}
            width="950"
            height="373"
            loading="eager"
            decoding="sync"
            fetchpriority="high"
          />
        </a>

        <nav class={styles.siteNav} aria-label="주요 메뉴">
          {
            siteConfig.nav.map((item) => (
              <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
          <RainSoundToggle />
        </nav>
      </header>

      <main id="content" class={styles.siteMain} data-site-main>
        <slot />
      </main>

      <footer class={styles.siteFooter}>
        <p>Copyright © 2026 All Right {siteConfig.author}</p>
        <ul aria-label="사이트 정보">
          <li>
            <a href={siteConfig.links.email} target="_blank" rel="noreferrer">{siteConfig.email}</a>
          </li>
          <li>
            <a href={siteConfig.links.github}>GitHub</a>
          </li>
          <li>
            <a href={siteConfig.repository.href}>{siteConfig.repository.label}</a>
          </li>
          <li>
            <a href={siteConfig.links.rss}>RSS</a>
          </li>
        </ul>
      </footer>
    </div>
  </body>
</html>
