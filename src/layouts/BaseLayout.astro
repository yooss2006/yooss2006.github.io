---
import { ClientRouter } from "astro:transitions";
import RainOverlay from "@/components/RainOverlay.astro";
import RainSoundToggle from "@/components/RainSoundToggle.astro";
import "@/styles/global.css";

interface Props {
  title: string;
  description: string;
  currentPath?: "/" | "/posts/" | "/about/";
}

const { title, description, currentPath } = Astro.props;

const navItems = [
  { href: "/posts/", label: "Posts" },
  { href: "/about/", label: "About" },
];
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <a class="skip-link" href="#content">본문으로 이동</a>
    <RainOverlay enabled={true} intensity="drizzle" />

    <div class="site-shell">
      <header class="site-header">
        <a class="site-title" href="/" aria-label="비가 내리네요. 홈">
          비가 내리네요.
        </a>

        <nav class="site-nav" aria-label="주요 메뉴">
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={currentPath === item.href ? "page" : undefined}>
                {item.label}
              </a>
            ))
          }
          <RainSoundToggle />
        </nav>
      </header>

      <main id="content" class="site-main">
        <slot />
      </main>

      <footer class="site-footer">
        <p>개발과 일상을 오래 남기는 개인 기록장</p>
      </footer>
    </div>
  </body>
</html>

<style>
  .skip-link {
    position: fixed;
    top: var(--space-4);
    left: var(--space-4);
    z-index: 10;
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border-strong);
    border-radius: var(--radius-sm);
    background: var(--color-bg-soft);
    color: var(--color-text);
    font-weight: 700;
    text-decoration: none;
    transform: translateY(-6rem);
    transition: transform 160ms ease;
  }

  .skip-link:focus-visible {
    transform: translateY(0);
  }

  .site-shell {
    position: relative;
    z-index: 1;
    width: min(100% - 2rem, var(--page-width));
    margin: 0 auto;
    padding: 0 0 var(--space-7);
  }

  .site-header {
    display: flex;
    min-height: var(--nav-height);
    gap: var(--space-5);
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--color-border);
    color: var(--color-text-muted);
  }

  .site-title {
    color: var(--color-text);
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 900;
    line-height: 1.1;
    text-decoration: none;
  }

  .site-nav {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    row-gap: var(--space-1);
    align-items: center;
    justify-content: flex-end;
    font-size: 0.9375rem;
  }

  .site-nav a {
    min-width: 2.625rem;
    padding: 0.35rem 0.55rem;
    border-radius: var(--radius-sm);
    color: inherit;
    line-height: 1.2;
    text-align: center;
    text-decoration: none;
  }

  .site-nav a:hover,
  .site-nav a[aria-current="page"] {
    background: var(--color-surface);
    color: var(--color-text);
  }

  .site-main {
    padding: var(--space-8) 0;
  }

  .site-footer {
    padding-top: var(--space-5);
    border-top: 1px solid var(--color-border);
  }

  .site-footer p {
    margin-bottom: 0;
    font-size: 0.875rem;
  }

  @media (max-width: 48rem) {
    .site-shell {
      width: min(100% - 1.25rem, var(--page-width));
    }

    .site-header {
      min-height: auto;
      padding: var(--space-4) 0;
    }

    .site-main {
      padding: var(--space-7) 0;
    }

    .site-nav {
      flex-wrap: wrap;
      justify-content: flex-end;
      gap: var(--space-1);
    }
  }
</style>
