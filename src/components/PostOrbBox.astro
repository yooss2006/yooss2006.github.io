---
import styles from "./PostOrbBox.module.css";

export type PostOrb = {
  readonly slug: string;
  readonly href: string;
  readonly title: string;
  readonly description: string;
  readonly category: string;
  readonly tone: number;
  readonly index: number;
};

interface Props {
  readonly posts: readonly PostOrb[];
}

const { posts } = Astro.props;
---

<section
  class={styles.postOrbBox}
  data-post-orb-box
  data-count={String(posts.length)}
  data-state={posts.length > 0 ? "initializing" : "fallback"}
  aria-labelledby="post-orb-box-title"
>
  {
    posts.length > 0 ? (
      <div class={styles.postOrbBoxField} data-post-orb-field>
        {posts.map((post) => (
          <a
            class={styles.postOrb}
            data-post-orb
            data-title={post.title}
            data-tone={String(post.tone)}
            data-index={String(post.index)}
            href={post.href}
            aria-label={`${post.title} 글로 이동`}
            title={post.title}
            tabindex="0"
          >
          </a>
        ))}
      </div>
    ) : (
      <p class={styles.postOrbBoxEmpty}>아직 공개된 글이 없습니다.</p>
    )
  }
</section>

<script>
  import { initializePostOrbBoxes } from "@/lib/post-orb-runtime";

  initializePostOrbBoxes();
</script>
