---
import { getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPageTitle } from "@/config/site";

const aboutPage = await getEntry("pages", "about");
if (!aboutPage) {
  throw new Error("src/content/pages/about.md 파일이 필요합니다.");
}

const { Content: AboutContent } = await render(aboutPage);
const pageTitle = getPageTitle(aboutPage.data.title);
---

<BaseLayout title={pageTitle} description={aboutPage.data.description} currentPath="/about/">
  <header>
    {aboutPage.data.eyebrow && <p>{aboutPage.data.eyebrow}</p>}
    <h1>{aboutPage.data.title}</h1>
    <p>{aboutPage.data.description}</p>
  </header>

  <AboutContent />
</BaseLayout>
