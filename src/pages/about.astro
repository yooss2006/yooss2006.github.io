---
import { getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPageTitle, siteConfig } from "@/config/site";
import styles from "./about.module.css";

const aboutPage = await getEntry("pages", "about");
if (!aboutPage) {
  throw new Error("src/content/pages/about.md 파일이 필요합니다.");
}

const { Content: AboutContent } = await render(aboutPage);
const pageTitle = getPageTitle(aboutPage.data.title);
const pageDescription = aboutPage.data.description ?? siteConfig.description;
---

<BaseLayout title={pageTitle} description={pageDescription} currentPath="/about/">
  <header class={styles.pageHeader}>
    {aboutPage.data.eyebrow && <p>{aboutPage.data.eyebrow}</p>}
    <h1>{aboutPage.data.title}</h1>
  </header>

  <AboutContent />
</BaseLayout>
