---
import { render } from "astro:content";
import { formatPostDate, getPublishedPosts, getPostSlug } from "@/lib/posts";

export async function getStaticPaths() {
  const posts = await getPublishedPosts();

  return posts.map((post) => ({
    params: { slug: getPostSlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const publishedAt = formatPostDate(post.data.publishedAt);
const updatedAt = post.data.updatedAt ? formatPostDate(post.data.updatedAt) : undefined;
const pageTitle = `${post.data.title} | 비가 내리네요.`;
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={post.data.description} />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main>
      <article>
        <a href="/">비가 내리네요.</a>

        <header>
          <p>{post.data.category}</p>
          <h1>{post.data.title}</h1>
          <p>{post.data.description}</p>
          <p>
            <time datetime={post.data.publishedAt.toISOString()}>{publishedAt}</time>
            {
              updatedAt && (
                <>
                  {" "}
                  <span>수정: </span>
                  <time datetime={post.data.updatedAt?.toISOString()}>{updatedAt}</time>
                </>
              )
            }
          </p>
          {
            post.data.tags.length > 0 && (
              <ul aria-label="태그">
                {post.data.tags.map((tag) => (
                  <li>{tag}</li>
                ))}
              </ul>
            )
          }
        </header>

        <Content />
      </article>
    </main>
  </body>
</html>
