---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPageTitle, siteConfig } from "@/config/site";
import { formatPostDate, getPostSlug, getPublishedPosts } from "@/lib/posts";

const posts = await getPublishedPosts();
const pageTitle = getPageTitle("글");
const description = `${siteConfig.name}의 전체 글 목록입니다.`;
---

<BaseLayout title={pageTitle} description={description} currentPath="/posts/">
  <header>
    <p>posts</p>
    <h1>글</h1>
    <p>개발과 일상 기록을 최신순으로 모았습니다.</p>
  </header>

  <section aria-labelledby="post-list-title">
    <h2 id="post-list-title">전체 글</h2>
    {
      posts.length > 0 ? (
        <ol>
          {posts.map((post) => {
            const slug = getPostSlug(post);
            const publishedAt = formatPostDate(post.data.publishedAt);

            return (
              <li>
                <article>
                  {post.data.thumbnail && <img src={post.data.thumbnail} alt="" loading="lazy" />}
                  <p>{post.data.category}</p>
                  <h3>
                    <a href={`/posts/${slug}/`}>{post.data.title}</a>
                  </h3>
                  <p>
                    <time datetime={post.data.publishedAt.toISOString()}>{publishedAt}</time>
                  </p>
                  <p>{post.data.description}</p>
                </article>
              </li>
            );
          })}
        </ol>
      ) : (
        <p>아직 공개된 글이 없습니다.</p>
      )
    }
  </section>
</BaseLayout>
