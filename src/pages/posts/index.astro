---
import { formatPostDate, getPostSlug, getPublishedPosts } from "@/lib/posts";

const posts = await getPublishedPosts();
const pageTitle = "글 | 비가 내리네요.";
---

<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="비가 내리네요.의 전체 글 목록입니다." />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <main>
      <a href="/">비가 내리네요.</a>

      <header>
        <p>posts</p>
        <h1>글</h1>
        <p>개발과 일상 기록을 최신순으로 모았습니다.</p>
      </header>

      <section aria-labelledby="post-list-title">
        <h2 id="post-list-title">전체 글</h2>
        {
          posts.length > 0 ? (
            <ol>
              {posts.map((post) => {
                const slug = getPostSlug(post);
                const publishedAt = formatPostDate(post.data.publishedAt);

                return (
                  <li>
                    <article>
                      {post.data.thumbnail && (
                        <img src={post.data.thumbnail} alt="" loading="lazy" />
                      )}
                      <p>{post.data.category}</p>
                      <h3>
                        <a href={`/posts/${slug}/`}>{post.data.title}</a>
                      </h3>
                      <p>
                        <time datetime={post.data.publishedAt.toISOString()}>{publishedAt}</time>
                      </p>
                      <p>{post.data.description}</p>
                    </article>
                  </li>
                );
              })}
            </ol>
          ) : (
            <p>아직 공개된 글이 없습니다.</p>
          )
        }
      </section>
    </main>
  </body>
</html>
