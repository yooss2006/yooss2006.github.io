---
import { getEntry, render } from "astro:content";
import PostOrbBox from "@/components/PostOrbBox.astro";
import { siteConfig } from "@/config/site";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPostSlug, getPublishedPosts } from "@/lib/posts";

const homePage = await getEntry("pages", "home");
if (!homePage) {
  throw new Error("src/content/pages/home.md 파일이 필요합니다.");
}

const { Content: HomeContent } = await render(homePage);
const pageDescription = homePage.data.description ?? siteConfig.description;
const posts = await getPublishedPosts();
const postOrbs = posts.map((post, index) => {
  const slug = getPostSlug(post);

  return {
    slug,
    href: `/posts/${slug}/`,
    title: post.data.title,
    description: post.data.description,
    category: post.data.category,
    tone: index % 6,
    index,
  };
});
---

<BaseLayout title={siteConfig.name} description={pageDescription} currentPath="/">
  {homePage.data.eyebrow && <p>{homePage.data.eyebrow}</p>}
  <h1>{homePage.data.title}</h1>
  <HomeContent />
  <PostOrbBox posts={postOrbs} />
</BaseLayout>
