---
import { getEntry, render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { formatPostDate, getPostSlug, getRecentPosts } from "@/lib/posts";

const homePage = await getEntry("pages", "home");
if (!homePage) {
  throw new Error("src/content/pages/home.md 파일이 필요합니다.");
}

const { Content: HomeContent } = await render(homePage);
const recentPosts = await getRecentPosts(5);
---

<BaseLayout title={homePage.data.title} description={homePage.data.description} currentPath="/">
  {homePage.data.eyebrow && <p>{homePage.data.eyebrow}</p>}
  <h1>{homePage.data.title}</h1>
  <HomeContent />
  <p>
    <a href="/posts/">글 보기</a>
    <a href="/about/">소개 보기</a>
  </p>

  <section aria-labelledby="recent-posts-title">
    <h2 id="recent-posts-title">최근 글</h2>
    {
      recentPosts.length > 0 ? (
        <ol>
          {recentPosts.map((post) => {
            const slug = getPostSlug(post);
            const publishedAt = formatPostDate(post.data.publishedAt);

            return (
              <li>
                <article>
                  <p>{post.data.category}</p>
                  <h3>
                    <a href={`/posts/${slug}/`}>{post.data.title}</a>
                  </h3>
                  <p>
                    <time datetime={post.data.publishedAt.toISOString()}>{publishedAt}</time>
                  </p>
                  <p>{post.data.description}</p>
                </article>
              </li>
            );
          })}
        </ol>
      ) : (
        <p>아직 공개된 글이 없습니다.</p>
      )
    }
  </section>
</BaseLayout>
